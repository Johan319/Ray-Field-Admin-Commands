-- Teleport Z
local function SetupTeleport(Char)
    local HumanoidRootPart = Char:WaitForChild("HumanoidRootPart")
    local Mouse = LocalPlayer:GetMouse()
    Mouse.KeyDown:Connect(function(Key)
        if Key == "z" and TeleportActive and Mouse.Target then
            HumanoidRootPart.CFrame = CFrame.new(Mouse.Hit.p + Vector3.new(0, 5, 0))
        end
    end)
end
if LocalPlayer.Character then SetupTeleport(LocalPlayer.Character) end
LocalPlayer.CharacterAdded:Connect(SetupTeleport)

