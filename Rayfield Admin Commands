-- ========== HELPERS ==========
local function RandomColor() return Color3.new(math.random(), math.random(), math.random()) end
local function GenerateRandomColorSequence()
    local Keypoints = {}
    for i = 0, 1, 0.1 do
        table.insert(Keypoints, ColorSequenceKeypoint.new(i, RandomColor()))
    end
    return ColorSequence.new(Keypoints)
end

local function StartRainbow()
    RainbowActive = true
    task.spawn(function()
        while RainbowActive do
            pcall(function()
                if UpdateLineColorsEvent then
                    UpdateLineColorsEvent:FireServer(GenerateRandomColorSequence())
                end
            end)
            task.wait(1)
        end
    end)
end
local function StopRainbow() RainbowActive = false end

local function StartFakeTyping()
    FakeTypingActive = true
    task.spawn(function()
        while FakeTypingActive do
            pcall(function() ReplicatedStorage.CharacterEvents.ChatTyping:FireServer("begin") end)
            task.wait(2)
        end
    end)
end
local function StopFakeTyping()
    FakeTypingActive = false
    pcall(function() ReplicatedStorage.CharacterEvents.ChatTyping:FireServer("end") end)
end

