-- ========== COMMAND HANDLER ==========
function handleCommand(msg)
    local parts = msg:lower():match("^%s*(.-)%s*$"):split(" ")
    local cmd = parts[1]

    if cmd == "walkspeed" or cmd == "ws" then
        local val = tonumber(parts[2])
        if val then
            CurrentWalkSpeed = math.clamp(val, 16, 1000)
            WalkSpeedEnabled = true
            if LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid") then
                LocalPlayer.Character:FindFirstChildOfClass("Humanoid").WalkSpeed = CurrentWalkSpeed
            end
            Rayfield:Notify({ Title = "WalkSpeed", Content = "Set to " .. CurrentWalkSpeed, Duration = 2 })
        end

    elseif cmd == "jumppower" or cmd == "jp" then
        local val = tonumber(parts[2])
        if val then
            CurrentJumpPower = math.clamp(val, 20, 1000)
            JumpPowerEnabled = true
            if LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid") then
                LocalPlayer.Character:FindFirstChildOfClass("Humanoid").JumpPower = CurrentJumpPower
            end
            Rayfield:Notify({ Title = "JumpPower", Content = "Set to " .. CurrentJumpPower, Duration = 2 })
        end

    elseif cmd == "fireanimations" or cmd == "fireanims" then
        FireAnimActive = true
        if FireAnimationTrack then FireAnimationTrack:Play() end
        Rayfield:Notify({ Title = "Fire Animation", Content = "Enabled", Duration = 2 })

    elseif cmd == "unfireanimations" or cmd == "unfireanims" then
        FireAnimActive = false
        if FireAnimationTrack then FireAnimationTrack:Stop() end
        Rayfield:Notify({ Title = "Fire Animation", Content = "Disabled", Duration = 2 })

    elseif cmd == "faketyping" or cmd == "fy" then
        StartFakeTyping()
        Rayfield:Notify({ Title = "Fake Typing", Content = "Enabled", Duration = 2 })

    elseif cmd == "unfaketyping" or cmd == "unfy" then
        StopFakeTyping()
        Rayfield:Notify({ Title = "Fake Typing", Content = "Disabled", Duration = 2 })

    elseif cmd == "rainbowbeams" or cmd == "rb" then
        StartRainbow()
        Rayfield:Notify({ Title = "Rainbow Beam", Content = "Enabled", Duration = 2 })

    elseif cmd == "unrainbowbeams" or cmd == "unrb" then
        StopRainbow()
        Rayfield:Notify({ Title = "Rainbow Beam", Content = "Disabled", Duration = 2 })

    elseif cmd == "teleportz" or cmd == "tpz" then
        TeleportActive = true
        TPButton.Visible = true
        LockBtn.Visible = true
        Rayfield:Notify({ Title = "Teleport", Content = "Enabled — Tap TP button", Duration = 2 })

    elseif cmd == "unteleportz" or cmd == "untpz" then
        TeleportActive = false
        TPButton.Visible = false
        LockBtn.Visible = false
        Rayfield:Notify({ Title = "Teleport", Content = "Disabled", Duration = 2 })

    elseif cmd == "rejoin" or cmd == "rj" then
        local TeleportService = game:GetService("TeleportService")
        TeleportService:Teleport(game.PlaceId, LocalPlayer)

    elseif cmd == "reset" or cmd == "respawn" or cmd == "rs" then
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid") then
            LocalPlayer.Character:FindFirstChildOfClass("Humanoid").Health = 0
        end

    elseif cmd == "noclip" then
        NoclipEnabled = true
        Rayfield:Notify({ Title = "Noclip", Content = "Enabled", Duration = 2 })

    elseif cmd == "unnoclip" then
        NoclipEnabled = false
        if LocalPlayer.Character then
            for _, Part in pairs(LocalPlayer.Character:GetDescendants()) do
                if Part:IsA("BasePart") then Part.CanCollide = true end
            end
        end
        Rayfield:Notify({ Title = "Noclip", Content = "Disabled", Duration = 2 })

    elseif cmd == "cmdbar" then
        SetCmdBar(not CmdBarEnabled)
    end
end

elseif cmd == "infinitejump" or cmd == "infjump" then
        InfiniteJumpEnabled = true
        Rayfield:Notify({ Title = "Infinite Jump", Content = "Enabled", Duration = 2 })

    elseif cmd == "uninfinitejump" or cmd == "uninfjump" then
        InfiniteJumpEnabled = false
        Rayfield:Notify({ Title = "Infinite Jump", Content = "Disabled", Duration = 2 })

-- Chat listener
local TextChatService = game:GetService("TextChatService")
if TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then
    TextChatService.OnIncomingMessage = function(msg)
        if msg.TextSource and msg.TextSource.UserId == LocalPlayer.UserId then
            local text = msg.Text
            if text:sub(1,1) == CurrentPrefix then
                handleCommand(text:sub(2))
            end
        end
    end
else
    LocalPlayer.Chatted:Connect(function(msg)
        if msg:sub(1,1) == CurrentPrefix then
            handleCommand(msg:sub(2))
        end
    end)
end

